APP_NAME=EasyMonitor
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Allow open user registration. When false (default) only the very first
# user can register; all subsequent registrations return 404.
REGISTRATION_ENABLED=false

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration (Docker)
# These credentials will be used to create the database user and database
# Change these before running 'docker compose up' for the first time
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=easymonitor
DB_USERNAME=easymonitor
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

HORIZON_ALLOWED_IPS=127.0.0.1

# Probe Node Configuration
# JWT_SECRET is used by the server to generate probe tokens (auto-generated by setup.sh)
JWT_SECRET=

# Local probe configuration (auto-configured by setup.sh)
PROBE_NODE_ID=local-node-1
PROBE_JWT_TOKEN=
# Use redis:// for non-TLS, rediss:// for TLS connections
PROBE_REDIS_URL=redis://redis:6379/0
# For production with TLS:
# PROBE_REDIS_URL=rediss://redis.example.com:6380/0
